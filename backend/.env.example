# Example environment file for AgroConnect backend
# Copy to .env and fill values before running in development/production

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/agroconnect

# Port for the backend server (default 5000)
PORT=5000

# Optional API key for AI features
API_KEY=

# JWT secret for authentication
JWT_SECRET=your_jwt_secret_here

# Node environment (development|production)
NODE_ENV=development
